@module "main"

@link("linking/main.o")

const Entity -> struct {
priv:
    id: int,

pub:
    x: float,
    y: float,

    static default -> fn () Entity {
        return Entity {
            id: 0,
            x: 0.0,
            y: 0.0
        };
    },

    move -> fn (dx: float, dy: float) void {
        self.x = self.x + dx;
        self.y = self.y + dy;
    },

    print_position -> fn () void { output("(", self.x, ", ", self.y, ")\n"); }
};

const Player -> struct {
    ...Entity,

    name: *byte,
    health: int,

    static create -> fn (name: *byte) Player {
        return Player {
            id: 1,
            x: 0.0,
            y: 0.0,
            name: name,
            health: 100
        };
    },

    take_damage -> fn (amount: int) void          = self.health = self.health - amount;
    move        -> fn (dx: float, dy: float) void = Entity.move(dx, dy);
};

const print -> fn () void;

pub const main -> fn () int {
    let player: Player = Player::create("Connor");

    player.move(10.0, 5.0);

    player.take_damage(25);

    output(player.name, "\n");
    output(player.health, "\n");
    output("(", player.x, ", ", player.y, ")\n");

    print();

    return 0;
}
