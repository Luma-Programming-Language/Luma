@module "main"

#returns_ownership
const add -> fn (x: int, y: int) *int {
    let result: *int = cast<*int>(alloc(sizeof<int>));
    *result = x + y;
    return result;
}

pub const main -> fn () int {
    const x: fn (int, int) *int = &add;

    let res: *int = x(10, 10);
    defer { free(res); } 
    
    output(*res, "\n");

    return 0;
}
