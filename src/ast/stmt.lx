@module "ast_stmt"

@use "ast" as AST

#returns_ownership
pub const make_program -> fn (modules: **AstNode, module_count: int, line: int, col: int) *AstNode {
  let node: *AstNode = cast<*AstNode>(alloc(sizeof<ProgramNode>));
  let base: *AstNode = node;
  let f: *int = cast<*int>(node);
  base.kind = AST::NodeType::PROGRAM;
  base.category = AST::NodeCategory::Node_Category_STMT;
  base.line = line;
  base.col = col;
  f[4] = cast<int>(modules);
  f[5] = module_count;
  return node;
}

#returns_ownership
pub const make_expr_stmt -> fn (expression: *AstNode, line: int, col: int) *AstNode {
  let node: *AstNode = cast<*AstNode>(alloc(sizeof<ExprStmtNode>));
  let base: *AstNode = node;
  let f: *int = cast<*int>(node);
  base.kind = AST::NodeType::STMT_EXPRESSION;
  base.category = AST::NodeCategory::Node_Category_STMT;
  base.line = line;
  base.col = col;
  f[4] = cast<int>(expression);
  return node;
}

#returns_ownership
pub const make_var_decl -> fn (name: *byte, doc_comment: *byte, var_type: *AstNode,
                               initializer: *AstNode, is_mutable: int, is_public: int, line: int, col: int) *AstNode {
  let node: *AstNode = cast<*AstNode>(alloc(sizeof<VarDeclNode>));
  let base: *AstNode = node;
  let f: *int = cast<*int>(node);
  base.kind = AST::NodeType::STMT_VAR_DECL;
  base.category = AST::NodeCategory::Node_Category_STMT;
  base.line = line;
  base.col = col;
  f[4] = cast<int>(name);
  f[5] = cast<int>(doc_comment);
  f[6] = cast<int>(var_type);
  f[7] = cast<int>(initializer);
  f[8] = is_mutable;
  f[9] = is_public;
  return node;
}

#returns_ownership
pub const make_const_decl -> fn (name: *byte, doc_comment: *byte, var_type: *AstNode,
                                 initializer: *AstNode, is_public: int, line: int, col: int) *AstNode {
  let node: *AstNode = cast<*AstNode>(alloc(sizeof<VarDeclNode>));
  let base: *AstNode = node;
  let f: *int = cast<*int>(node);
  base.kind = AST::NodeType::STMT_CONST_DECL;
  base.category = AST::NodeCategory::Node_Category_STMT;
  base.line = line;
  base.col = col;
  f[4] = cast<int>(name);
  f[5] = cast<int>(doc_comment);
  f[6] = cast<int>(var_type);
  f[7] = cast<int>(initializer);
  f[8] = 0;
  f[9] = is_public;
  return node;
}

#returns_ownership
pub const make_func_decl -> fn (name: *byte, doc_comment: *byte, param_names: **byte, param_types: **AstNode,
                                param_count: int, return_type: *AstNode, is_public: int, body: *AstNode,
                                returns_ownership: int, takes_ownership: int,
                                forward_declared: int, line: int, col: int) *AstNode {
  let node: *AstNode = cast<*AstNode>(alloc(sizeof<FuncDeclNode>));
  let base: *AstNode = node;
  let f: *int = cast<*int>(node);
  base.kind = AST::NodeType::STMT_FUNCTION;
  base.category = AST::NodeCategory::Node_Category_STMT;
  base.line = line;
  base.col = col;
  f[4]  = cast<int>(name);
  f[5]  = cast<int>(doc_comment);
  f[6]  = cast<int>(param_names);
  f[7]  = cast<int>(param_types);
  f[8]  = param_count;
  f[9]  = cast<int>(return_type);
  f[10] = is_public;
  f[11] = cast<int>(body);
  f[12] = returns_ownership;
  f[13] = takes_ownership;
  f[14] = forward_declared;
  return node;
}

