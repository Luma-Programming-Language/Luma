#returns_ownership
pub const make_if_stmt -> fn (condition: *AstNode, then_stmt: *AstNode, elif_stmts: **AstNode,
                              elif_count: int, else_stmt: *AstNode, line: int, col: int) *AstNode {
  let node: *IfStmtNode = cast<*IfStmtNode>(alloc(sizeof<IfStmtNode>));
  let base: *AstNode    = cast<*AstNode>(node);
  base.kind     = AST::NodeType::STMT_IF;
  base.category = AST::NodeCategory::Node_Category_STMT;
  base.line     = line;
  base.col      = col;
  node.condition  = condition;
  node.then_stmt  = then_stmt;
  node.elif_stmts = elif_stmts;
  node.elif_count = elif_count;
  node.else_stmt  = else_stmt;
  return base;
}

#returns_ownership
pub const make_loop_stmt -> fn (condition: *AstNode, optional: *AstNode, body: *AstNode,
                                initializer: **AstNode, init_count: int, line: int, col: int) *AstNode {
  let node: *LoopStmtNode = cast<*LoopStmtNode>(alloc(sizeof<LoopStmtNode>));
  let base: *AstNode      = cast<*AstNode>(node);
  base.kind     = AST::NodeType::STMT_LOOP;
  base.category = AST::NodeCategory::Node_Category_STMT;
  base.line     = line;
  base.col      = col;
  node.condition   = condition;
  node.optional    = optional;
  node.body        = body;
  node.initializer = initializer;
  node.init_count  = init_count;
  return base;
}

