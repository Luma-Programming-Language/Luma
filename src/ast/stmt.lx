pub const make_print_stmt -> fn (expressions: **AstNode, expr_count: int, ln: int, line: int, col: int) *AstNode {
  let node: *PrintStmtNode = cast<*PrintStmtNode>(alloc(sizeof<PrintStmtNode>));
  let base: *AstNode       = cast<*AstNode>(node);
  base.kind     = AST::NodeType::STMT_PRINT;
  base.category = AST::NodeCategory::Node_Category_STMT;
  base.line     = line;
  base.col      = col;
