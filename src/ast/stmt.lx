#returns_ownership
pub const make_switch_stmt -> fn (condition: *AstNode, cases: **AstNode, case_count: int,
                                  default_case: *AstNode, line: int, col: int) *AstNode {
  let node: *SwitchNode = cast<*SwitchNode>(alloc(sizeof<SwitchNode>));
  let base: *AstNode    = cast<*AstNode>(node);
  base.kind     = AST::NodeType::STMT_SWITCH;
  base.category = AST::NodeCategory::Node_Category_STMT;
  base.line     = line;
  base.col      = col;
  node.condition    = condition;
  node.cases        = cases;
  node.case_count   = case_count;
  node.default_case = default_case;
  return base;
}

#returns_ownership
pub const make_impl_stmt -> fn (function_name_list: **byte, function_type_list: **AstNode, struct_name_list: **byte,
                                function_name_count: int, struct_name_count: int, body: *AstNode,
                                line: int, col: int) *AstNode {
  let node: *ImplNode = cast<*ImplNode>(alloc(sizeof<ImplNode>));
  let base: *AstNode  = cast<*AstNode>(node);
  base.kind     = AST::NodeType::STMT_IMPL;
  base.category = AST::NodeCategory::Node_Category_STMT;
  base.line     = line;
  base.col      = col;
  node.function_name_list  = function_name_list;
  node.function_type_list  = function_type_list;
  node.struct_name_list    = struct_name_list;
  node.function_name_count = function_name_count;
  node.struct_name_count   = struct_name_count;
  node.body                = body;
  return base;
}

