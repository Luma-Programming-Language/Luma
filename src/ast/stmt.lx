@module "ast_stmt"

@use "ast" as AST

#returns_ownership
pub const make_program -> fn (modules: **AstNode, module_count: int, line: int, col: int) *AstNode {
  let node: *ProgramNode = cast<*ProgramNode>(alloc(sizeof<ProgramNode>));
  let base: *AstNode     = cast<*AstNode>(node);
  base.kind     = AST::NodeType::PROGRAM;
  base.category = AST::NodeCategory::Node_Category_STMT;
  base.line     = line;
  base.col      = col;
  node.modules      = modules;
  node.module_count = module_count;
  return base;
}

#returns_ownership
pub const make_expr_stmt -> fn (expression: *AstNode, line: int, col: int) *AstNode {
  let node: *ExprStmtNode = cast<*ExprStmtNode>(alloc(sizeof<ExprStmtNode>));
  let base: *AstNode      = cast<*AstNode>(node);
  base.kind     = AST::NodeType::STMT_EXPRESSION;
  base.category = AST::NodeCategory::Node_Category_STMT;
  base.line     = line;
  base.col      = col;
  node.expression = expression;
  return base;
}

#returns_ownership
pub const make_var_decl -> fn (name: *byte, doc_comment: *byte, var_type: *AstNode,
                               initializer: *AstNode, is_mutable: int, is_public: int, line: int, col: int) *AstNode {
  let node: *VarDeclNode = cast<*VarDeclNode>(alloc(sizeof<VarDeclNode>));
  let base: *AstNode     = cast<*AstNode>(node);
  base.kind     = AST::NodeType::STMT_VAR_DECL;
  base.category = AST::NodeCategory::Node_Category_STMT;
  base.line     = line;
  base.col      = col;
  node.name        = name;
  node.doc_comment = doc_comment;
  node.var_type    = var_type;
  node.initializer = initializer;
  node.is_mutable  = is_mutable;
  node.is_public   = is_public;
  return base;
}

#returns_ownership
pub const make_const_decl -> fn (name: *byte, doc_comment: *byte, var_type: *AstNode,
                                 initializer: *AstNode, is_public: int, line: int, col: int) *AstNode {
  let node: *VarDeclNode = cast<*VarDeclNode>(alloc(sizeof<VarDeclNode>));
  let base: *AstNode     = cast<*AstNode>(node);
  base.kind     = AST::NodeType::STMT_CONST_DECL;
  base.category = AST::NodeCategory::Node_Category_STMT;
  base.line     = line;
  base.col      = col;
  node.name        = name;
  node.doc_comment = doc_comment;
  node.var_type    = var_type;
  node.initializer = initializer;
  node.is_mutable  = 0;
  node.is_public   = is_public;
  return base;
}

#returns_ownership
pub const make_func_decl -> fn (name: *byte, doc_comment: *byte, param_names: **byte, param_types: **AstNode,
                                param_count: int, return_type: *AstNode, is_public: int, body: *AstNode,
                                returns_ownership: int, takes_ownership: int,
                                forward_declared: int, line: int, col: int) *AstNode {
  let node: *FuncDeclNode = cast<*FuncDeclNode>(alloc(sizeof<FuncDeclNode>));
  let base: *AstNode      = cast<*AstNode>(node);
  base.kind     = AST::NodeType::STMT_FUNCTION;
  base.category = AST::NodeCategory::Node_Category_STMT;
  base.line     = line;
  base.col      = col;
  node.name              = name;
  node.doc_comment       = doc_comment;
  node.param_names       = param_names;
  node.param_types       = param_types;
  node.param_count       = param_count;
  node.return_type       = return_type;
  node.is_public         = is_public;
  node.body              = body;
  node.returns_ownership = returns_ownership;
  node.takes_ownership   = takes_ownership;
  node.forward_declared  = forward_declared;
  return base;
}

#returns_ownership
pub const make_struct_decl -> fn (name: *byte, doc_comment: *byte, public_members: **AstNode,
                                  public_count: int, private_members: **AstNode, private_count: int,
                                  is_public: int, line: int, col: int) *AstNode {
  let node: *StructDeclNode = cast<*StructDeclNode>(alloc(sizeof<StructDeclNode>));
  let base: *AstNode        = cast<*AstNode>(node);
  base.kind     = AST::NodeType::STMT_STRUCT;
  base.category = AST::NodeCategory::Node_Category_STMT;
  base.line     = line;
  base.col      = col;
  node.name            = name;
  node.doc_comment     = doc_comment;
  node.public_members  = public_members;
  node.public_count    = public_count;
  node.private_members = private_members;
  node.private_count   = private_count;
  node.is_public       = is_public;
  return base;
}

#returns_ownership
pub const make_field_decl -> fn (name: *byte, doc_comment: *byte, type_node: *AstNode,
                                 function: *AstNode, is_public: int, line: int, col: int) *AstNode {
  let node: *FieldDeclNode = cast<*FieldDeclNode>(alloc(sizeof<FieldDeclNode>));
  let base: *AstNode       = cast<*AstNode>(node);
  base.kind     = AST::NodeType::STMT_FIELD_DECL;
  base.category = AST::NodeCategory::Node_Category_STMT;
  base.line     = line;
  base.col      = col;
  node.name        = name;
  node.doc_comment = doc_comment;
  node.type_node   = type_node;
  node.function    = function;
  node.is_public   = is_public;
  return base;
}

#returns_ownership
pub const make_enum_decl -> fn (name: *byte, doc_comment: *byte, members: **byte,
                                member_count: int, is_public: int, line: int, col: int) *AstNode {
  let node: *EnumDeclNode = cast<*EnumDeclNode>(alloc(sizeof<EnumDeclNode>));
  let base: *AstNode      = cast<*AstNode>(node);
  base.kind     = AST::NodeType::STMT_ENUM;
  base.category = AST::NodeCategory::Node_Category_STMT;
  base.line     = line;
  base.col      = col;
  node.name         = name;
  node.doc_comment  = doc_comment;
  node.members      = members;
