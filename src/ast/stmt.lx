@module "ast_stmt"

@use "ast" as AST

#returns_ownership
pub const make_program -> fn (modules: **AstNode, module_count: int, line: int, col: int) *AstNode {
  let n: *ProgramNode = cast<*ProgramNode>(alloc(sizeof<ProgramNode>));
  let base: *AstNode = cast<*AstNode>(n);

  base.kind = AST::NodeType::PROGRAM;
  base.category = AST::NodeCategory::Node_Category_STMT;
  base.line = line;

  base.col = col;
  n.modules = modules;
  n.module_count = module_count;

  return cast<*AstNode>(n);
}

#returns_ownership
pub const make_expr_stmt -> fn (expression: *AstNode, line: int, col: int) *AstNode {
  let n: *ExprStmtNode = cast<*ExprStmtNode>(alloc(sizeof<ExprStmtNode>));
  let base: *AstNode = cast<*AstNode>(n);

  base.kind = AST::NodeType::STMT_EXPRESSION;
  base.category = AST::NodeCategory::Node_Category_STMT;
  base.line = line;
  base.col = col;

  n.expression = expression;

  return cast<*AstNode>(n);
}

#returns_ownership
pub const make_var_decl -> fn (name: *byte, doc_comment: *byte, var_type: *AstNode,
                               initializer: *AstNode, is_mutable: int, is_public: int, line: int, col: int) *AstNode {
  let n: *VarDeclNode = cast<*VarDeclNode>(alloc(sizeof<VarDeclNode>));
  let base: *AstNode = cast<*AstNode>(n);

  base.kind = AST::NodeType::STMT_VAR_DECL;
  base.category = AST::NodeCategory::Node_Category_STMT;
  base.line = line;
  base.col = col;

  n.name = name;
  n.doc_comment = doc_comment;
  n.var_type = var_type;
  n.initializer = initializer;
  n.is_mutable = is_mutable;
  n.is_public = is_public;

  return cast<*AstNode>(n);
}

#returns_ownership
pub const make_const_decl -> fn (name: *byte, doc_comment: *byte, var_type: *AstNode,
                                 initializer: *AstNode, is_public: int, line: int, col: int) *AstNode {
  let n: *VarDeclNode = cast<*VarDeclNode>(alloc(sizeof<VarDeclNode>));
  let base: *AstNode = cast<*AstNode>(n);

  base.kind = AST::NodeType::STMT_CONST_DECL;
  base.category = AST::NodeCategory::Node_Category_STMT;
  base.line = line;
  base.col = col;

  n.name = name;
  n.doc_comment = doc_comment;
  n.var_type = var_type;
  n.initializer = initializer;
  n.is_mutable = 0;
  n.is_public = is_public;

  return cast<*AstNode>(n);
}

#returns_ownership
pub const make_func_decl -> fn (name: *byte, doc_comment: *byte, param_names: **byte, param_types: **AstNode,
                                param_count: int, return_type: *AstNode, is_public: int, body: *AstNode,
                                returns_ownership: int, takes_ownership: int,
                                forward_declared: int, line: int, col: int) *AstNode {
  let n: *FuncDeclNode = cast<*FuncDeclNode>(alloc(sizeof<FuncDeclNode>));
  let base: *AstNode = cast<*AstNode>(n);

  base.kind = AST::NodeType::STMT_FUNCTION;
  base.category = AST::NodeCategory::Node_Category_STMT;
  base.line = line;
  base.col = col;

  n.name = name;
  n.doc_comment = doc_comment;
  n.param_names = param_names;
  n.param_types = param_types;
  n.param_count = param_count;
  n.return_type = return_type;
  n.is_public = is_public;
  n.body = body;
  n.returns_ownership = returns_ownership;
  n.takes_ownership = takes_ownership;
  n.forward_declared = forward_declared;

  return cast<*AstNode>(n);
}

#returns_ownership
pub const make_struct_decl -> fn (name: *byte, doc_comment: *byte, public_members: **AstNode,
                                  public_count: int, private_members: **AstNode, private_count: int,
                                  is_public: int, line: int, col: int) *AstNode {
  let n: *StructDeclNode = cast<*StructDeclNode>(alloc(sizeof<StructDeclNode>));
  let base: *AstNode = cast<*AstNode>(n);

  base.kind = AST::NodeType::STMT_STRUCT;
  base.category = AST::NodeCategory::Node_Category_STMT;
  base.line = line;
  base.col = col;

  n.name = name;
  n.doc_comment = doc_comment;
  n.public_members = public_members;
  n.public_count = public_count;
  n.private_members = private_members;
  n.private_count = private_count;
  n.is_public = is_public;

  return cast<*AstNode>(n);
}

