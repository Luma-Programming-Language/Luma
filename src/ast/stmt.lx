#returns_ownership
pub const make_if_stmt -> fn (condition: *AstNode, then_stmt: *AstNode, elif_stmts: **AstNode,
                              elif_count: int, else_stmt: *AstNode, line: int, col: int) *AstNode {
  let n: *IfStmtNode = cast<*IfStmtNode>(alloc(sizeof<IfStmtNode>));
  let base: *AstNode = cast<*AstNode>(n);

  base.kind = AST::NodeType::STMT_IF;
  base.category = AST::NodeCategory::Node_Category_STMT;
  base.line = line;
  base.col = col;

  n.condition = condition;
  n.then_stmt = then_stmt;
  n.elif_stmts = elif_stmts;
  n.elif_count = elif_count;
  n.else_stmt = else_stmt;

  return cast<*AstNode>(n);
}

