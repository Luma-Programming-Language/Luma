#returns_ownership
pub const make_impl_stmt -> fn (function_name_list: **byte, function_type_list: **AstNode, struct_name_list: **byte,
                                function_name_count: int, struct_name_count: int, body: *AstNode,
                                line: int, col: int) *AstNode {
  let n: *ImplNode = cast<*ImplNode>(alloc(sizeof<ImplNode>));
  let base: *AstNode = cast<*AstNode>(n);

  base.kind = AST::NodeType::STMT_IMPL;
  base.category = AST::NodeCategory::Node_Category_STMT;
  base.line = line;
  base.col = col;

  n.function_name_list = function_name_list;
  n.function_type_list = function_type_list;
  n.struct_name_list = struct_name_list;
  n.function_name_count = function_name_count;
  n.struct_name_count = struct_name_count;
  n.body = body;

  return cast<*AstNode>(n);
}

